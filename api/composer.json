{
    "name": "cyclingcommons/api",
    "description": "Cycling Commons serving API (Symfony) — dev scaffold",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.12",
        "symfony/dotenv": "^7.1",
        "symfony/framework-bundle": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/yaml": "^7.1"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
