# Cycling Commons — dev stack config.
# Copy to `.env` (which is gitignored) and adjust as needed:
#   cp developers/docker/.env.example developers/docker/.env

# ---- host ports ----
ATLAS_PORT=8099
WIKI_PORT=8000
API_PORT=8001
PIPELINE_PORT=8002
VALHALLA_PORT=8003
# Host-side ports only (the container always serves on 9000/9001 internally).
# Off MinIO's defaults (9000/9001) to avoid clashing with another MinIO/S3 mock.
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101

# ---- Postgres / PostGIS ----
POSTGRES_DB=cyclingcommons
POSTGRES_USER=cc
POSTGRES_PASSWORD=cc
# Host-side port only (the container always listens on 5432, and the app
# services reach it as `db:5432`). Defaults to 5433 to avoid clashing with a
# PostgreSQL you may already run locally on 5432.
POSTGRES_PORT=5433

# ---- Symfony API ----
APP_SECRET=dev-not-secret-change-me

# ---- downloaded heavy data (opt-in profiles; kept out of git) ----
# DEM directory mounted into the pipeline at /data/dem.
DEM_DIR=./data/dem
# Prebuilt Valhalla tiles (profile: routing) mounted at /custom_files.
VALHALLA_TILES=./data/valhalla

# ---- MinIO (profile: storage) ----
MINIO_ROOT_USER=ccadmin
MINIO_ROOT_PASSWORD=ccadminsecret
